{
  "name": "arpon-inertia-bridge",
  "version": "0.1.0",
  "description": "Express middleware bridge for Inertia.js with Vite (React + Vue adapter mode)",
  "author": "Arpon",
  "keywords": [
    "express",
    "inertia",
    "react",
    "vue",
    "vite",
    "middleware",
    "seo",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "release:check": "npm test && npm run build && npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run release:check"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@types/express": "^4.17.23",
    "@types/supertest": "^6.0.3",
    "express": "^5.1.0",
    "supertest": "^7.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

