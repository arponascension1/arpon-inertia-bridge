{
  "name": "arpon-inertia-bridge-vue-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 node --watch server.mjs",
    "dev:client": "vite --host 127.0.0.1 --port 5174",
    "build": "vite build",
    "start": "node server.mjs"
  },
  "dependencies": {
    "@inertiajs/vue3": "^2.2.15",
    "arpon-inertia-bridge": "file:..",
    "express": "^5.1.0",
    "nprogress": "^0.2.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.2.2",
    "vite": "^7.1.12"
  }
}
